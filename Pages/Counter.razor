@page "/counter"
@inject Length_Calculator.SessionState.CounterState CounterState

<PageTitle>Counter</PageTitle>

<h1>Counter</h1>

<p role="status">Current count: @CounterState.Counter.ToString()</p>

<button class="btn btn-primary" @onclick="IncrementCount">Click me</button>

@code {

    private void IncrementCount()
    {
        CounterState.Counter++;
    }
}
